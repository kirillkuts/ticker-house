# Trigger.dev — prod environment variables
#
# Set these in the Trigger dashboard: your project → the "prod" environment →
# Environment Variables. Deployed tasks do NOT read a local .env file; this is
# the runtime environment for the chat agent (web/trigger/chat.ts) and the
# daily briefing (web/trigger/daily-sync.ts).
#
# Secrets below are PLACEHOLDERS — paste your real values into the dashboard.
# Do not commit real secrets to the repo. Hostnames/ports/flags are real and
# are the parts that are easy to get wrong.

# --- ClickHouse Cloud (market data) -----------------------------------------
# App/Trigger use the HTTPS interface on :8443.
CLICKHOUSE_URL=https://p0mxmisof7.us-east1.gcp.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<clickhouse-cloud-password>
CLICKHOUSE_DB=ticker_house

# --- Managed Postgres (app data) --------------------------------------------
# The ?sslmode=require&uselibpqcompat=true suffix is REQUIRED. Newer node-pg
# treats a plain sslmode=require as full CA verification, which fails on this
# cert chain; uselibpqcompat=true restores encrypt-without-verify (what psql
# does). Without it the tasks cannot connect.
DATABASE_URL=postgresql://postgres:<postgres-password>@tickerhouse-oltp-e75ae279.pgw2zzjt28se1q5sqpd91cptgn.c0.us-east-1.aws.pg.clickhouse.cloud:5432/postgres?sslmode=require&uselibpqcompat=true

# --- LLM: chat agent + briefing ---------------------------------------------
# The one that bites first if missing — both tasks call it.
OPENROUTER_KEY=<openrouter-key>

# --- Email: daily briefing --------------------------------------------------
GMAIL_USER=<you@gmail.com>
GMAIL_APP_PASSWORD=<gmail-app-password>
# Optional: pin every briefing email to one inbox. Leave empty to send each
# user their own account email.
BRIEFING_TO=

# --- App --------------------------------------------------------------------
# Your deployed app's URL, so the email "ask" links open prod, not localhost.
APP_URL=https://<your-app-domain>

# App host (Vercel / any Node host) — environment variables
#
# Set these on the app host. IMPORTANT: set the host's project ROOT DIRECTORY
# to `web/` — the app lives there, and there are two lockfiles in the repo.
#
# Superset of the Trigger vars (the app also renders briefings and sends email
# via its "Run now" button, and it talks to Trigger to run the chat agent).
# Secrets are PLACEHOLDERS — fill real values in the host's env settings.

# --- ClickHouse Cloud (market data) -----------------------------------------
CLICKHOUSE_URL=https://p0mxmisof7.us-east1.gcp.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<clickhouse-cloud-password>
CLICKHOUSE_DB=ticker_house

# --- Managed Postgres (app data) --------------------------------------------
# Keep the ?sslmode=require&uselibpqcompat=true suffix or the driver won't connect.
DATABASE_URL=postgresql://postgres:<postgres-password>@tickerhouse-oltp-e75ae279.pgw2zzjt28se1q5sqpd91cptgn.c0.us-east-1.aws.pg.clickhouse.cloud:5432/postgres?sslmode=require&uselibpqcompat=true

# --- LLM (explain popover, session summary, "Run now" briefing) -------------
OPENROUTER_KEY=<openrouter-key>

# --- Email (the "Run briefing now" button) ----------------------------------
GMAIL_USER=<you@gmail.com>
GMAIL_APP_PASSWORD=<gmail-app-password>
BRIEFING_TO=

# --- Trigger.dev (the app starts the chat agent + mints access tokens) ------
# From your Trigger project settings. The secret key is the prod (deploy) key.
TRIGGER_PROJECT_REF=proj_ommldbjgeksxrwlqrnkn
TRIGGER_SECRET_KEY=<trigger-prod-secret-key>

# --- App's own URL (email "ask" links) --------------------------------------
# Set to the deployed domain once the host gives you one.
APP_URL=https://<your-app-domain>

# Copy to web/.env.local (Next.js) and web/.env (Trigger.dev worker).
# Both are gitignored.

# LLM access for the chat agent.
OPENROUTER_KEY=

# ClickHouse (read side). Defaults match the repo docker-compose.yml.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=ticker
CLICKHOUSE_PASSWORD=ticker
CLICKHOUSE_DB=ticker_house

# Postgres: users, sessions, saved chats and dashboards.
DATABASE_URL=postgresql://ticker:ticker@localhost:5432/ticker_house

# Trigger.dev: the chat agent runs as a Trigger task.
TRIGGER_PROJECT_REF=proj_REPLACE_ME
TRIGGER_SECRET_KEY=
# Absolute path to the repo root, used by the daily-sync task to shell out
# to the data pipeline. Leave unset to auto-detect by walking up from cwd.
REPO_ROOT=

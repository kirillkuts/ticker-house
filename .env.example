# Copy to .env and fill in. .env is gitignored.
# This file covers the data pipeline (npm run sync:*). The web app has its
# own web/.env.example.

# ── Data pipeline ───────────────────────────────────────────────
# Massive API key: daily prices + company profile enrichment.
MASSIVE_API_KEY=

# SEC's fair-access policy wants a descriptive User-Agent with a real
# contact email. https://www.sec.gov/os/webmaster-faq#developers
SEC_USER_AGENT=TickerHouse you@example.com

# ClickHouse. Defaults match docker-compose.yml (local dev only).
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=ticker
CLICKHOUSE_PASSWORD=ticker
CLICKHOUSE_DB=ticker_house

# Postgres, used by sync:filings. Default matches docker-compose.yml.
DATABASE_URL=postgresql://ticker:ticker@localhost:5432/ticker_house
